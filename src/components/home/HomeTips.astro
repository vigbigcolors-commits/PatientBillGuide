---
import { homeTips } from '../../data/home-content';
---

<section class="home-tips" aria-labelledby="home-tips-heading">
  <div class="container">
    <header class="section-header section-header--center">
      <p class="section-eyebrow">Practical advice</p>
      <h2 id="home-tips-heading">Strong tips for every situation</h2>
      <p class="section-lead">
        Actionable steps — not legal advice. Use them alongside our free tools and guides.
      </p>
    </header>
    <div class="tips-grid">
      {
        homeTips.map((block, i) => (
          <article class="tip-panel">
            <div class="tip-panel__header">
              <span class={`tip-panel__icon tip-panel__icon--${i}`} aria-hidden="true">
                {i === 0 && (
                  <svg width="22" height="22" viewBox="0 0 24 24" fill="none">
                    <rect x="3" y="6" width="18" height="14" rx="2" stroke="currentColor" stroke-width="1.5" />
                    <path d="M3 10h18" stroke="currentColor" stroke-width="1.5" />
                  </svg>
                )}
                {i === 1 && (
                  <svg width="22" height="22" viewBox="0 0 24 24" fill="none">
                    <path d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2" stroke="currentColor" stroke-width="1.5" />
                    <rect x="9" y="3" width="6" height="4" rx="1" stroke="currentColor" stroke-width="1.5" />
                  </svg>
                )}
                {i === 2 && (
                  <svg width="22" height="22" viewBox="0 0 24 24" fill="none">
                    <path d="M4 18l4-8 4 4 4-6 4 10" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" />
                  </svg>
                )}
              </span>
              <h3>{block.title}</h3>
            </div>
            <ul>
              {block.items.map((item) => (
                <li>{item}</li>
              ))}
            </ul>
          </article>
        ))
      }
    </div>
    <p class="home-tips__cta">
      <a href="/how-it-works/" class="btn btn--primary">See our full approach</a>
      <a href="/methodology/" class="btn btn--secondary">Methodology & data sources</a>
    </p>
  </div>
</section>

<style>
  .home-tips {
    padding: var(--space-3xl) 0;
    background: var(--color-bg);
  }

  .tips-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-lg);
    margin-bottom: var(--space-2xl);
  }

  .tip-panel {
    padding: var(--space-xl);
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-xl);
    box-shadow: var(--shadow-sm);
  }

  .tip-panel__header {
    display: flex;
    align-items: center;
    gap: var(--space-md);
    margin-bottom: var(--space-md);
  }

  .tip-panel__icon {
    display: grid;
    place-items: center;
    width: 2.5rem;
    height: 2.5rem;
    border-radius: var(--radius-md);
    flex-shrink: 0;
  }

  .tip-panel__icon--0 {
    background: #fef3c7;
    color: #b45309;
  }

  .tip-panel__icon--1 {
    background: #dbeafe;
    color: #1d4ed8;
  }

  .tip-panel__icon--2 {
    background: #d1fae5;
    color: #047857;
  }

  .tip-panel h3 {
    margin: 0;
    font-size: 1rem;
  }

  .tip-panel ul {
    margin: 0;
    padding-left: 1.15rem;
    font-size: 0.9rem;
    color: var(--color-muted);
    line-height: 1.7;
  }

  .tip-panel li + li {
    margin-top: var(--space-sm);
  }

  .home-tips__cta {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: var(--space-md);
    margin: 0;
  }

  @media (max-width: 900px) {
    .tips-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
