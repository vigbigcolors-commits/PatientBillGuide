---
import type { LearnGuide } from '../../data/learn-hub-content';

interface Props {
  guide: LearnGuide;
  featured?: boolean;
}

const { guide, featured = false } = Astro.props;
---

<a
  href={guide.href}
  class:list={['lg', `lg--${guide.tone}`, featured && 'lg--featured']}
>
  <div class="lg__decor" aria-hidden="true">
    <span class="lg__ring" />
    <span class="lg__dots" />
  </div>
  <div class="lg__content">
    <header class="lg__head">
      <span class="lg__audience">{guide.audience}</span>
      <span class="lg__time">{guide.readTime}</span>
    </header>
    <blockquote class="lg__pain">"{guide.question}"</blockquote>
    <h3 class="lg__title">{guide.title}</h3>
    <p class="lg__text">{guide.text}</p>
    <footer class="lg__foot">
      <span class="lg__read">
        Read guide
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" aria-hidden="true">
          <path d="M5 12h14M13 6l6 6-6 6" stroke="currentColor" stroke-width="2" stroke-linecap="round" />
        </svg>
      </span>
      {
        guide.toolHref && (
          <span class="lg__tool">{guide.toolLabel}</span>
        )
      }
    </footer>
  </div>
</a>

<style>
  .lg {
    position: relative;
    display: flex;
    flex-direction: column;
    height: 100%;
    border-radius: 1.125rem;
    border: 1px solid transparent;
    overflow: hidden;
    text-decoration: none;
    color: inherit;
    box-shadow: 0 2px 8px rgb(15 23 42 / 0.06);
    transition: transform 0.22s ease, box-shadow 0.22s ease;
  }

  .lg:hover {
    transform: translateY(-4px);
    box-shadow: 0 16px 32px rgb(15 23 42 / 0.1);
  }

  .lg:hover .lg__read svg {
    transform: translateX(3px);
  }

  .lg__decor {
    position: absolute;
    inset: 0;
    z-index: 0;
    pointer-events: none;
    overflow: hidden;
  }

  .lg__ring {
    position: absolute;
    top: -1rem;
    right: -1rem;
    width: 4rem;
    height: 4rem;
    border: 1.5px solid currentColor;
    border-radius: 50%;
    opacity: 0.1;
  }

  .lg__dots {
    position: absolute;
    bottom: 0.5rem;
    right: 0.5rem;
    width: 2.5rem;
    height: 2.5rem;
    opacity: 0.1;
    background-image: radial-gradient(circle, currentColor 1px, transparent 1px);
    background-size: 7px 7px;
  }

  .lg__content {
    position: relative;
    z-index: 1;
    display: flex;
    flex-direction: column;
    flex: 1;
    padding: 1.125rem;
  }

  .lg--featured .lg__content {
    padding: 1.375rem;
  }

  .lg--teal {
    background: linear-gradient(155deg, #f0fdfa 0%, #ccfbf1 100%);
    border-color: #5eead4;
    color: #0f766e;
  }

  .lg--blue {
    background: linear-gradient(155deg, #eff6ff 0%, #bfdbfe 100%);
    border-color: #93c5fd;
    color: #1e40af;
  }

  .lg--violet {
    background: linear-gradient(155deg, #f5f3ff 0%, #ddd6fe 100%);
    border-color: #c4b5fd;
    color: #5b21b6;
  }

  .lg--amber {
    background: linear-gradient(155deg, #fffbeb 0%, #fde68a 100%);
    border-color: #fcd34d;
    color: #92400e;
  }

  .lg--rose {
    background: linear-gradient(155deg, #fff1f2 0%, #fecdd3 100%);
    border-color: #fda4af;
    color: #9f1239;
  }

  .lg--green {
    background: linear-gradient(155deg, #f0fdf4 0%, #bbf7d0 100%);
    border-color: #86efac;
    color: #166534;
  }

  .lg--slate {
    background: linear-gradient(155deg, #f8fafc 0%, #e2e8f0 100%);
    border-color: #cbd5e1;
    color: #334155;
  }

  .lg__head {
    display: flex;
    gap: 0.375rem;
    margin-bottom: 0.625rem;
  }

  .lg__audience,
  .lg__time {
    font-size: 0.5625rem;
    font-weight: 800;
    letter-spacing: 0.07em;
    text-transform: uppercase;
    padding: 0.2rem 0.5rem;
    border-radius: 999px;
    background: #fff;
    border: 1px solid rgb(0 0 0 / 0.06);
  }

  .lg__time {
    color: inherit;
    opacity: 0.75;
  }

  .lg__pain {
    margin: 0 0 0.625rem;
    padding: 0.5rem 0.625rem;
    font-size: 0.875rem;
    font-weight: 600;
    font-style: italic;
    line-height: 1.35;
    background: #fff;
    border-left: 3px solid currentColor;
    border-radius: 0 0.375rem 0.375rem 0;
    border: 1px solid rgb(0 0 0 / 0.06);
    border-left: 3px solid currentColor;
  }

  .lg--featured .lg__pain {
    font-size: 0.9375rem;
  }

  .lg__title {
    margin: 0 0 0.375rem;
    font-family: var(--font-heading);
    font-size: 1.0625rem;
    font-weight: 700;
    line-height: 1.25;
    letter-spacing: -0.02em;
    color: inherit;
  }

  .lg--featured .lg__title {
    font-size: 1.1875rem;
  }

  .lg__text {
    margin: 0 0 1rem;
    flex: 1;
    font-size: 0.8125rem;
    line-height: 1.6;
    color: inherit;
    opacity: 0.9;
  }

  .lg__foot {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.5rem;
    padding-top: 0.75rem;
    border-top: 1px solid rgb(0 0 0 / 0.08);
  }

  .lg__read {
    display: inline-flex;
    align-items: center;
    gap: 0.25rem;
    font-size: 0.8125rem;
    font-weight: 700;
    color: inherit;
  }

  .lg__read svg {
    transition: transform 0.2s ease;
  }

  .lg__tool {
    font-size: 0.6875rem;
    font-weight: 700;
    padding: 0.25rem 0.5rem;
    border-radius: 999px;
    background: #fff;
    border: 1px solid rgb(0 0 0 / 0.08);
    color: inherit;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    max-width: 9rem;
  }
</style>
