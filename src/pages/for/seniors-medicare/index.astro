---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../../components/Breadcrumbs.astro';
import Disclaimer from '../../../components/Disclaimer.astro';
import { site } from '../../../data/site';
import { author, getAuthorUrl } from '../../../data/author';
import {
  medicareMeta,
  medicareTrust,
  medicareFlow,
  medicarePainPoints,
  medicareSteps,
  medicareConcepts,
  medicareParts,
  medicareTools,
  medicareFaqs,
} from '../../../data/seniors-medicare-content';
import {
  articleSchema,
  breadcrumbSchema,
  faqPageSchema,
  medicalWebPageSchema,
} from '../../../lib/seo/schema';

const pageUrl = '/for/seniors-medicare/';
const canonical = new URL(pageUrl, site.url).href;
const authorUrl = getAuthorUrl(site.url);

const schemaGraph = [
  medicalWebPageSchema({
    name: medicareMeta.title,
    description: medicareMeta.description,
    url: canonical,
    dateModified: medicareMeta.updated,
    authorName: author.name,
    authorUrl,
    authorJobTitle: author.jobTitle,
  }),
  articleSchema({
    headline: medicareMeta.title,
    description: medicareMeta.description,
    url: canonical,
    dateModified: medicareMeta.updated,
    authorName: author.name,
    authorUrl,
    authorJobTitle: author.jobTitle,
  }),
  faqPageSchema(medicareFaqs),
  breadcrumbSchema(
    [{ name: 'Home', url: '/' }, { name: 'For Seniors & Medicare' }],
    site.url,
  ),
];
---

<BaseLayout title={medicareMeta.title} description={medicareMeta.description} showTrustStrip>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(schemaGraph)} />
  </Fragment>

  {/* Hero */}
  <section class="mc-hero" aria-labelledby="mc-hero-heading">
    <div class="mc-hero__bg" aria-hidden="true">
      <span class="mc-blob mc-blob--1" />
      <span class="mc-blob mc-blob--2" />
      <span class="mc-grid" />
    </div>
    <div class="container mc-hero__inner">
      <Breadcrumbs
        items={[
          { label: 'Home', href: '/' },
          { label: 'Learn', href: '/learn/' },
          { label: 'Medicare' },
        ]}
      />
      <div class="mc-hero__layout">
        <div class="mc-hero__copy">
          <p class="mc-kicker">Seniors · Caregivers · Medicare</p>
          <h1 id="mc-hero-heading">Medicare billing — in plain English</h1>
          <p class="mc-hero__lead">
            MSNs, Part B coinsurance, facility fees, and participating doctors — Medicare paperwork
            has its own vocabulary. We help you <strong>read statements</strong>,{' '}
            <strong>check CMS public rates</strong>, and call billing with specific facts.
          </p>
          <div class="mc-hero__actions">
            <a href="/tools/fair-price/?tab=medicare" class="btn btn--primary">Medicare lookup</a>
            <a href="#mc-flow" class="btn btn--secondary">How it works</a>
          </div>
        </div>

        <div class="mc-hero__flow" aria-label="Medicare workflow">
          <p class="mc-hero__flow-label">Your 3-step path</p>
          {
            medicareFlow.map((step, i) => (
              <>
                <a href={step.href} class={`mc-flow-step mc-flow-step--${step.accent}`}>
                  <span class="mc-flow-step__num">{step.step}</span>
                  <span class="mc-flow-step__emoji" aria-hidden="true">{step.emoji}</span>
                  <span class="mc-flow-step__label">{step.label}</span>
                  <strong class="mc-flow-step__title">{step.title}</strong>
                  <span class="mc-flow-step__text">{step.text}</span>
                </a>
                {i < medicareFlow.length - 1 && (
                  <span class="mc-flow-arrow" aria-hidden="true">↓</span>
                )}
              </>
            ))
          }
        </div>
      </div>
    </div>
  </section>

  {/* Trust */}
  <section class="mc-trust" aria-label="Medicare page highlights">
    <div class="container mc-trust__grid">
      {
        medicareTrust.map((t) => (
          <div class={`mc-trust-chip mc-trust-chip--${t.accent}`}>
            <strong>{t.label}</strong>
            <span>{t.detail}</span>
          </div>
        ))
      }
    </div>
  </section>

  {/* Pipeline */}
  <section class="mc-pipeline" id="mc-flow" aria-labelledby="mc-pipeline-heading">
    <div class="container">
      <header class="mc-pipeline__head">
        <h2 id="mc-pipeline-heading">READ → CHECK → ASK</h2>
        <p>Most Medicare confusion clears up once you know which document you hold and what CMS published for your code.</p>
      </header>
      <ol class="mc-pipeline__track">
        {
          medicareFlow.map((step) => (
            <li class={`mc-pipeline__step mc-pipeline__step--${step.accent}`}>
              <span class="mc-pipeline__badge">{step.label}</span>
              <span class="mc-pipeline__emoji" aria-hidden="true">{step.emoji}</span>
              <h3>{step.title}</h3>
              <p>{step.text}</p>
              <a href={step.href} class="mc-pipeline__link">Go →</a>
            </li>
          ))
        }
      </ol>
    </div>
  </section>

  {/* Pain points */}
  <section class="mc-pain" id="mc-paperwork" aria-labelledby="mc-pain-heading">
    <div class="container">
      <header class="mc-section-head mc-section-head--center">
        <p class="mc-kicker mc-kicker--dark">Common questions</p>
        <h2 id="mc-pain-heading">What seniors and caregivers ask us</h2>
        <p class="mc-section-lead">Six situations we built tools and guides around — tap any card for the next step.</p>
      </header>
      <ol class="mc-pain__grid">
        {
          medicarePainPoints.map((p, i) => (
            <li class={`mc-pain-card mc-pain-card--${p.tone}`}>
              <span class="mc-pain-card__rank">{String(i + 1).padStart(2, '0')}</span>
              <p class="mc-pain-card__q">"{p.question}"</p>
              <h3>{p.title}</h3>
              <p class="mc-pain-card__text">{p.text}</p>
              <a href={p.href} class="mc-pain-card__link">{p.linkLabel} →</a>
            </li>
          ))
        }
      </ol>
    </div>
  </section>

  {/* Steps */}
  <section class="mc-steps" id="mc-steps" aria-labelledby="mc-steps-heading">
    <div class="container">
      <header class="mc-section-head">
        <p class="mc-kicker mc-kicker--dark">Playbook</p>
        <h2 id="mc-steps-heading">Four steps when you have a Medicare balance</h2>
      </header>
      <ol class="mc-steps__track">
        {
          medicareSteps.map((s) => (
            <li class={`mc-step mc-step--${s.accent}`}>
              <span class="mc-step__num">{s.num}</span>
              <div class="mc-step__body">
                <h3>{s.title}</h3>
                <p>{s.text}</p>
                {
                  s.toolHref && (
                    <a href={s.toolHref} class="mc-step__tool">
                      <span>Tool</span>
                      {s.toolLabel} →
                    </a>
                  )
                }
              </div>
            </li>
          ))
        }
      </ol>
    </div>
  </section>

  {/* Concepts */}
  <section class="mc-concepts" id="mc-concepts" aria-labelledby="mc-concepts-heading">
    <div class="container">
      <header class="mc-section-head mc-section-head--center">
        <p class="mc-kicker mc-kicker--light">Vocabulary</p>
        <h2 id="mc-concepts-heading">Five terms worth knowing</h2>
        <p class="mc-section-lead mc-section-lead--light">Medicare billing jargon — translated without a coding manual.</p>
      </header>
      <ul class="mc-concepts__grid">
        {
          medicareConcepts.map((c) => (
            <li class={`mc-concept mc-concept--${c.tone}`}>
              <h3>{c.term}</h3>
              <p>{c.def}</p>
            </li>
          ))
        }
      </ul>
    </div>
  </section>

  {/* Parts A/B/C */}
  <section class="mc-parts" id="mc-parts" aria-labelledby="mc-parts-heading">
    <div class="container">
      <header class="mc-section-head mc-section-head--center">
        <p class="mc-kicker mc-kicker--dark">Coverage map</p>
        <h2 id="mc-parts-heading">Which part of Medicare is this?</h2>
        <p class="mc-section-lead">Different parts → different paperwork. Know where to look before you call.</p>
      </header>
      <div class="mc-parts__grid">
        {
          medicareParts.map((p) => (
            <article class={`mc-part mc-part--${p.accent}`}>
              <span class="mc-part__badge">{p.part}</span>
              <h3>{p.label}</h3>
              <p class="mc-part__examples">{p.examples}</p>
              <p class="mc-part__paperwork">
                <strong>Paperwork:</strong> {p.paperwork}
              </p>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  {/* Tools */}
  <section class="mc-tools" aria-labelledby="mc-tools-heading">
    <div class="container">
      <header class="mc-section-head">
        <p class="mc-kicker mc-kicker--dark">Free tools</p>
        <h2 id="mc-tools-heading">Check numbers before you call Medicare or billing</h2>
      </header>
      <ul class="mc-tools__grid">
        {
          medicareTools.map((t) => (
            <li>
              <a href={t.href} class={`mc-tool-card mc-tool-card--${t.accent}`}>
                <h3>{t.title}</h3>
                <p>{t.text}</p>
                <span class="mc-tool-card__cta">Open →</span>
              </a>
            </li>
          ))
        }
      </ul>
    </div>
  </section>

  {/* FAQ */}
  <section class="mc-faq" aria-labelledby="mc-faq-heading">
    <div class="container">
      <header class="mc-faq__header">
        <div>
          <p class="mc-kicker mc-kicker--dark">FAQ</p>
          <h2 id="mc-faq-heading">Medicare billing questions</h2>
        </div>
        <span class="mc-faq__count">{medicareFaqs.length} answers</span>
      </header>
      <div class="mc-faq__panel">
        <ul class="mc-faq__list" role="list">
          {
            medicareFaqs.map((f, i) => (
              <li>
                <button
                  type="button"
                  class:list={['mc-faq__q', i === 0 && 'is-active']}
                  aria-expanded={i === 0 ? 'true' : 'false'}
                  data-mc-faq={i}
                >
                  {f.question}
                </button>
                <div class:list={['mc-faq__a', i === 0 && 'is-open']} hidden={i !== 0}>
                  <p>{f.answer}</p>
                </div>
              </li>
            ))
          }
        </ul>
        <aside class="mc-faq__aside">
          <h3>Free help beyond this site</h3>
          <p>
            <strong>SHIP counselors</strong> offer unbiased Medicare help in every state — at no cost.
            Call <strong>1-800-MEDICARE</strong> for official Medicare questions.
          </p>
          <p>
            <a href="/methodology/">Our methodology →</a><br />
            <a href="/learn/">Learn hub →</a><br />
            <a href="/contact/">Contact us</a>
          </p>
          <p class="mc-faq__byline">
            By <a href={author.path}>{author.name}</a> · Updated {medicareMeta.updated}
          </p>
        </aside>
      </div>
      <div class="visually-hidden" aria-hidden="true">
        {medicareFaqs.map((f) => <p><strong>{f.question}</strong> {f.answer}</p>)}
      </div>
    </div>
  </section>

  {/* CTA */}
  <section class="mc-cta" aria-label="Get started">
    <div class="container mc-cta__box">
      <div class="mc-cta__copy">
        <h2>One code, one ZIP — Medicare allowed amount</h2>
        <p>Most caregivers start here before calling billing or comparing an MSN line.</p>
      </div>
      <div class="mc-cta__actions">
        <a href="/tools/fair-price/?tab=medicare" class="btn btn--primary">Medicare tab in Fair Price</a>
        <a href="/tools/medicare-lookup/" class="btn btn--secondary">Medicare Lookup</a>
      </div>
    </div>
  </section>

  <div class="container container--narrow mc-disclaimer">
    <Disclaimer />
  </div>
</BaseLayout>

<script>
  document.querySelectorAll('.mc-faq__q').forEach((btn) => {
    btn.addEventListener('click', () => {
      document.querySelectorAll('.mc-faq__q').forEach((b) => {
        b.classList.remove('is-active');
        b.setAttribute('aria-expanded', 'false');
      });
      document.querySelectorAll('.mc-faq__a').forEach((a) => {
        a.classList.remove('is-open');
        a.setAttribute('hidden', '');
      });
      btn.classList.add('is-active');
      btn.setAttribute('aria-expanded', 'true');
      const panel = btn.nextElementSibling;
      if (panel?.classList.contains('mc-faq__a')) {
        panel.classList.add('is-open');
        panel.removeAttribute('hidden');
      }
    });
  });
</script>

<style>
  .mc-kicker {
    margin: 0 0 0.625rem;
    font-size: 0.75rem;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: #059669;
  }

  .mc-kicker--dark { color: var(--color-accent); }
  .mc-kicker--light { color: #6ee7b7; }

  .mc-section-head {
    margin-bottom: clamp(2rem, 4vw, 2.75rem);
    max-width: 42rem;
  }

  .mc-section-head--center {
    text-align: center;
    margin-inline: auto;
  }

  .mc-section-head h2 {
    margin: 0 0 0.75rem;
    font-family: var(--font-heading);
    font-size: clamp(1.625rem, 3.5vw, 2.25rem);
    letter-spacing: -0.025em;
  }

  .mc-section-lead {
    margin: 0;
    font-size: 1.0625rem;
    line-height: 1.65;
    color: var(--color-muted);
  }

  .mc-section-lead--light {
    color: rgb(203 213 225 / 0.85);
  }

  /* Hero — green/teal theme */
  .mc-hero {
    position: relative;
    padding: 2rem 0 2.5rem;
    background: linear-gradient(180deg, #fafaf9 0%, #ecfdf5 55%, #f0fdfa 100%);
    border-bottom: 1px solid #d1fae5;
    overflow: hidden;
  }

  .mc-hero__bg {
    position: absolute;
    inset: 0;
    pointer-events: none;
  }

  .mc-blob {
    position: absolute;
    border-radius: 50%;
    filter: blur(70px);
  }

  .mc-blob--1 {
    width: 20rem;
    height: 20rem;
    top: -5rem;
    right: 5%;
    background: rgb(16 185 129 / 0.22);
  }

  .mc-blob--2 {
    width: 14rem;
    height: 14rem;
    bottom: 0;
    left: -2rem;
    background: rgb(13 148 136 / 0.18);
  }

  .mc-grid {
    position: absolute;
    inset: 0;
    opacity: 0.03;
    background-image: linear-gradient(#047857 1px, transparent 1px),
      linear-gradient(90deg, #047857 1px, transparent 1px);
    background-size: 28px 28px;
  }

  .mc-hero__inner {
    position: relative;
    z-index: 1;
  }

  .mc-hero__layout {
    display: grid;
    grid-template-columns: 1fr 0.95fr;
    gap: clamp(1.5rem, 3vw, 2.5rem);
    align-items: center;
  }

  .mc-hero h1 {
    margin: 0 0 1rem;
    font-family: var(--font-heading);
    font-size: clamp(2rem, 4.5vw, 2.875rem);
    font-weight: 700;
    line-height: 1.12;
    letter-spacing: -0.03em;
    color: var(--color-primary);
  }

  .mc-hero__lead {
    margin: 0 0 1.75rem;
    font-size: 1.0625rem;
    line-height: 1.7;
    color: var(--color-muted);
  }

  .mc-hero__actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.875rem;
  }

  .mc-hero__flow {
    display: flex;
    flex-direction: column;
    gap: 0.375rem;
    padding: 1.25rem;
    border-radius: 1.25rem;
    background: #fff;
    border: 1px solid #a7f3d0;
    box-shadow: 0 8px 32px rgb(5 150 105 / 0.1);
  }

  .mc-hero__flow-label {
    margin: 0 0 0.25rem;
    font-size: 0.6875rem;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: #059669;
  }

  .mc-flow-step {
    display: grid;
    grid-template-columns: auto auto 1fr;
    grid-template-rows: auto auto;
    gap: 0.2rem 0.625rem;
    padding: 0.75rem 0.875rem;
    border-radius: 0.75rem;
    text-decoration: none;
    color: inherit;
    border: 1px solid transparent;
    transition: transform 0.2s, box-shadow 0.2s;
  }

  .mc-flow-step:hover {
    transform: translateX(4px);
    box-shadow: 0 4px 12px rgb(15 23 42 / 0.08);
  }

  .mc-flow-step--green {
    background: linear-gradient(135deg, #f0fdf4, #dcfce7);
    border-color: #86efac;
    color: #166534;
  }

  .mc-flow-step--teal {
    background: linear-gradient(135deg, #f0fdfa, #ccfbf1);
    border-color: #5eead4;
    color: #0f766e;
  }

  .mc-flow-step--blue {
    background: linear-gradient(135deg, #eff6ff, #dbeafe);
    border-color: #93c5fd;
    color: #1e40af;
  }

  .mc-flow-step__num {
    grid-row: 1 / 3;
    display: grid;
    place-items: center;
    width: 1.625rem;
    height: 1.625rem;
    border-radius: 50%;
    font-size: 0.6875rem;
    font-weight: 800;
    background: #fff;
    border: 1px solid rgb(0 0 0 / 0.08);
  }

  .mc-flow-step__emoji { font-size: 1rem; line-height: 1; }

  .mc-flow-step__label {
    font-size: 0.5625rem;
    font-weight: 800;
    letter-spacing: 0.1em;
    opacity: 0.75;
  }

  .mc-flow-step__title {
    grid-column: 2 / 4;
    font-size: 0.8125rem;
    font-weight: 700;
  }

  .mc-flow-step__text {
    grid-column: 2 / 4;
    font-size: 0.6875rem;
    line-height: 1.4;
    opacity: 0.88;
  }

  .mc-flow-arrow {
    text-align: center;
    font-size: 0.875rem;
    color: #059669;
    opacity: 0.4;
    line-height: 1;
  }

  /* Trust */
  .mc-trust {
    padding: 1rem 0;
    background: #fff;
    border-bottom: 1px solid #e7e5e4;
  }

  .mc-trust__grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 0.625rem;
  }

  .mc-trust-chip {
    padding: 0.75rem 1rem;
    border-radius: 0.875rem;
    border: 1px solid transparent;
  }

  .mc-trust-chip strong {
    display: block;
    font-size: 0.8125rem;
    font-weight: 700;
    margin-bottom: 0.15rem;
  }

  .mc-trust-chip span {
    font-size: 0.6875rem;
    line-height: 1.4;
    opacity: 0.88;
  }

  .mc-trust-chip--teal { background: #f0fdfa; border-color: #99f6e4; color: #0f766e; }
  .mc-trust-chip--green { background: #f0fdf4; border-color: #bbf7d0; color: #166534; }
  .mc-trust-chip--blue { background: #eff6ff; border-color: #bfdbfe; color: #1e40af; }
  .mc-trust-chip--amber { background: #fffbeb; border-color: #fde68a; color: #92400e; }

  /* Pipeline */
  .mc-pipeline {
    padding: clamp(2.5rem, 5vw, 3.5rem) 0;
    background: linear-gradient(155deg, #064e3b 0%, #0f172a 100%);
    color: #f8fafc;
  }

  .mc-pipeline__head {
    text-align: center;
    max-width: 38rem;
    margin: 0 auto 2rem;
  }

  .mc-pipeline__head h2 {
    margin: 0 0 0.625rem;
    font-family: var(--font-heading);
    font-size: clamp(1.375rem, 3vw, 1.875rem);
    color: #fff;
    letter-spacing: 0.02em;
  }

  .mc-pipeline__head p {
    margin: 0;
    color: rgb(167 243 208 / 0.85);
    line-height: 1.6;
  }

  .mc-pipeline__track {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1rem;
  }

  .mc-pipeline__step {
    padding: 1.5rem;
    border-radius: 1.25rem;
    background: rgb(255 255 255 / 0.06);
    border: 1px solid rgb(255 255 255 / 0.12);
    text-align: center;
  }

  .mc-pipeline__step--green { border-top: 3px solid #4ade80; }
  .mc-pipeline__step--teal { border-top: 3px solid #2dd4bf; }
  .mc-pipeline__step--blue { border-top: 3px solid #60a5fa; }

  .mc-pipeline__badge {
    display: inline-block;
    margin-bottom: 0.5rem;
    font-size: 0.625rem;
    font-weight: 800;
    letter-spacing: 0.12em;
    padding: 0.25rem 0.625rem;
    border-radius: 999px;
    background: rgb(255 255 255 / 0.1);
    color: #6ee7b7;
  }

  .mc-pipeline__emoji {
    display: block;
    font-size: 2rem;
    margin-bottom: 0.5rem;
  }

  .mc-pipeline__step h3 {
    margin: 0 0 0.5rem;
    font-size: 1.0625rem;
    color: #fff;
  }

  .mc-pipeline__step p {
    margin: 0 0 1rem;
    font-size: 0.8125rem;
    line-height: 1.55;
    color: rgb(203 213 225 / 0.85);
  }

  .mc-pipeline__link {
    font-size: 0.875rem;
    font-weight: 700;
    color: #6ee7b7;
    text-decoration: none;
  }

  /* Pain cards */
  .mc-pain {
    padding: clamp(3rem, 6vw, 4.5rem) 0;
    background: var(--color-bg);
  }

  .mc-pain__grid {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1rem;
  }

  .mc-pain-card {
    position: relative;
    padding: 1.375rem;
    border-radius: 1.125rem;
    border: 1px solid transparent;
    box-shadow: 0 2px 10px rgb(15 23 42 / 0.05);
    transition: transform 0.2s, box-shadow 0.2s;
  }

  .mc-pain-card:hover {
    transform: translateY(-3px);
    box-shadow: 0 12px 28px rgb(15 23 42 / 0.09);
  }

  .mc-pain-card--teal { background: linear-gradient(155deg, #f0fdfa, #ccfbf1); border-color: #5eead4; color: #0f766e; }
  .mc-pain-card--green { background: linear-gradient(155deg, #f0fdf4, #bbf7d0); border-color: #86efac; color: #166534; }
  .mc-pain-card--blue { background: linear-gradient(155deg, #eff6ff, #bfdbfe); border-color: #93c5fd; color: #1e40af; }
