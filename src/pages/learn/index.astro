---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import Disclaimer from '../../components/Disclaimer.astro';
import LearnGuideCard from '../../components/learn/LearnGuideCard.astro';
import { site } from '../../data/site';
import { author, getAuthorUrl } from '../../data/author';
import {
  learnMeta,
  learnTrust,
  learnFlow,
  learnClusters,
  learnJourneys,
  learnGuides,
  learnRoadmap,
  learnPrinciples,
  learnFaqs,
} from '../../data/learn-hub-content';
import {
  articleSchema,
  breadcrumbSchema,
  faqPageSchema,
  medicalWebPageSchema,
} from '../../lib/seo/schema';

const pageUrl = '/learn/';
const canonical = new URL(pageUrl, site.url).href;
const authorUrl = getAuthorUrl(site.url);
const featuredGuides = learnGuides.slice(0, 3);
const moreGuides = learnGuides.slice(3);

const schemaGraph = [
  medicalWebPageSchema({
    name: learnMeta.title,
    description: learnMeta.description,
    url: canonical,
    dateModified: learnMeta.updated,
    authorName: author.name,
    authorUrl,
    authorJobTitle: author.jobTitle,
  }),
  articleSchema({
    headline: learnMeta.title,
    description: learnMeta.description,
    url: canonical,
    dateModified: learnMeta.updated,
    authorName: author.name,
    authorUrl,
    authorJobTitle: author.jobTitle,
  }),
  faqPageSchema(learnFaqs),
  breadcrumbSchema([{ name: 'Home', url: '/' }, { name: 'Learn' }], site.url),
];
---

<BaseLayout title={learnMeta.title} description={learnMeta.description} showTrustStrip>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(schemaGraph)} />
  </Fragment>

  {/* ── Hero: light split + flow diagram ── */}
  <section class="ln-hero" aria-labelledby="ln-hero-heading">
    <div class="ln-hero__bg" aria-hidden="true">
      <span class="ln-blob ln-blob--1" />
      <span class="ln-blob ln-blob--2" />
      <span class="ln-blob ln-blob--3" />
      <span class="ln-grid" />
    </div>
    <div class="container ln-hero__inner">
      <Breadcrumbs items={[{ label: 'Home', href: '/' }, { label: 'Learn' }]} />
      <div class="ln-hero__layout">
        <div class="ln-hero__copy">
          <p class="ln-kicker">READ → CHECK → ACT</p>
          <h1 id="ln-hero-heading">Learn billing — then verify with free tools</h1>
          <p class="ln-hero__lead">
            Plain-English guides for hospital bills, insurance EOBs, and CPT codes. Every article
            hands you to a <strong>browser-only check</strong> — no upload, no account, no jargon wall.
          </p>
          <div class="ln-hero__actions">
            <a href="/learn/how-to-read-medical-bill/" class="btn btn--primary">Start: medical bill</a>
            <a href="#ln-flow" class="btn btn--secondary">See how it works</a>
          </div>
        </div>

        <div class="ln-hero__flow" aria-label="How Learn works">
          <p class="ln-hero__flow-label">How it works</p>
          {
            learnFlow.map((step, i) => (
              <>
                <a href={step.href} class={`ln-flow-step ln-flow-step--${step.accent}`}>
                  <span class="ln-flow-step__num">{step.step}</span>
                  <span class="ln-flow-step__emoji" aria-hidden="true">{step.emoji}</span>
                  <span class="ln-flow-step__label">{step.label}</span>
                  <strong class="ln-flow-step__title">{step.title}</strong>
                  <span class="ln-flow-step__text">{step.text}</span>
                </a>
                {i < learnFlow.length - 1 && (
                  <span class="ln-flow-arrow" aria-hidden="true">→</span>
                )}
              </>
            ))
          }
        </div>
      </div>
    </div>
  </section>

  {/* ── Trust chips ── */}
  <section class="ln-trust-strip" aria-label="Learn highlights">
    <div class="container ln-trust-strip__grid">
      {
        learnTrust.map((t) => (
          <div class={`ln-trust-chip ln-trust-chip--${t.accent}`}>
            <strong>{t.label}</strong>
            <span>{t.detail}</span>
          </div>
        ))
      }
    </div>
  </section>

  {/* ── Pipeline strip ── */}
  <section class="ln-pipeline" id="ln-flow" aria-labelledby="ln-pipeline-heading">
    <div class="container">
      <header class="ln-pipeline__head">
        <h2 id="ln-pipeline-heading">Three steps — always in this order</h2>
        <p>You do not need every guide. Read what matches your paperwork, check with a tool, then act.</p>
      </header>
      <ol class="ln-pipeline__track">
        {
          learnFlow.map((step) => (
            <li class={`ln-pipeline__step ln-pipeline__step--${step.accent}`}>
              <span class="ln-pipeline__badge">{step.label}</span>
              <span class="ln-pipeline__emoji" aria-hidden="true">{step.emoji}</span>
              <h3>{step.title}</h3>
              <p>{step.text}</p>
              <a href={step.href} class="ln-pipeline__link">Go →</a>
            </li>
          ))
        }
      </ol>
    </div>
  </section>

  {/* ── Pick your path ── */}
  <section class="ln-paths" aria-labelledby="ln-paths-heading">
    <div class="container">
      <header class="ln-section-head ln-section-head--center">
        <p class="ln-kicker ln-kicker--dark">Start here</p>
        <h2 id="ln-paths-heading">Which paperwork do you have?</h2>
        <p class="ln-section-lead">Three colored paths — each with numbered steps and a paired tool.</p>
      </header>
      <ul class="ln-paths__grid">
        {
          learnJourneys.map((j) => (
            <li class={`ln-path ln-path--${j.accent}`}>
              <div class="ln-path__top">
                <span class="ln-path__emoji" aria-hidden="true">{j.emoji}</span>
                <h3>{j.title}</h3>
              </div>
              <ol class="ln-path__steps">
                {
                  j.steps.map((s) => (
                    <li>
                      <span class="ln-path__step-num">{s.num}</span>
                      {s.text}
                    </li>
                  ))
                }
              </ol>
              <div class="ln-path__actions">
                <a href={j.href} class="ln-path__cta">{j.cta}</a>
                <a href={j.toolHref} class="ln-path__tool">
                  <span class="ln-path__tool-tag">Tool</span>
                  {j.toolLabel} →
                </a>
              </div>
            </li>
          ))
        }
      </ul>
    </div>
  </section>

  {/* ── Cluster lanes ── */}
  <section class="ln-clusters" aria-labelledby="ln-clusters-heading">
    <div class="container">
      <header class="ln-section-head ln-section-head--center">
        <p class="ln-kicker ln-kicker--light">Site map</p>
        <h2 id="ln-clusters-heading">CHECK · UNDERSTAND · ACT</h2>
        <p class="ln-section-lead ln-section-lead--light">
          Same organization as our tools — find the guide or calculator that fits your moment.
        </p>
      </header>
      <div class="ln-clusters__grid">
        {
          learnClusters.map((cluster) => (
            <article class={`ln-cluster ln-cluster--${cluster.accent}`}>
              <header class="ln-cluster__head">
                <span class="ln-cluster__id">{cluster.id}</span>
                <h3>{cluster.title}</h3>
                <p>{cluster.subtitle}</p>
              </header>
              <ul class="ln-cluster__list">
                {
                  cluster.items.map((item) => (
                    <li>
                      <a href={item.href} class:list={['ln-cluster__link', item.tool && 'ln-cluster__link--tool']}>
                        {item.tool && <span class="ln-cluster__tool-dot" aria-hidden="true" />}
                        {item.label}
                      </a>
                    </li>
                  ))
                }
              </ul>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  {/* ── Guides bento ── */}
  <section class="ln-guides" aria-labelledby="ln-guides-heading">
    <div class="container">
      <header class="ln-section-head">
        <p class="ln-kicker ln-kicker--dark">Live guides</p>
        <h2 id="ln-guides-heading">8 resources — each pairs with a tool</h2>
        <p class="ln-section-lead">Top three are the pillars most patients need first.</p>
      </header>
      <div class="ln-bento">
        {
          featuredGuides.map((g) => (
            <div class="ln-bento__featured">
              <LearnGuideCard guide={g} featured />
            </div>
          ))
        }
        {
          moreGuides.map((g) => (
            <div class="ln-bento__item">
              <LearnGuideCard guide={g} />
            </div>
          ))
        }
      </div>
    </div>
  </section>

  {/* ── Principles ── */}
  <section class="ln-principles" aria-labelledby="ln-principles-heading">
    <div class="container">
      <header class="ln-section-head ln-section-head--center">
        <p class="ln-kicker ln-kicker--dark">How we write</p>
        <h2 id="ln-principles-heading">Editorial standards — not marketing fluff</h2>
      </header>
      <ul class="ln-principles__grid">
        {
          learnPrinciples.map((p) => (
            <li class={`ln-principle ln-principle--${p.accent}`}>
              <span class="ln-principle__num">{p.num}</span>
              <h3>{p.title}</h3>
              <p>{p.text}</p>
            </li>
          ))
        }
      </ul>
    </div>
  </section>

  {/* ── Roadmap timeline ── */}
  <section class="ln-roadmap" aria-labelledby="ln-roadmap-heading">
    <div class="container">
      <header class="ln-section-head ln-section-head--center">
        <p class="ln-kicker ln-kicker--dark">Coming next</p>
        <h2 id="ln-roadmap-heading">More guides shipping — tools ready now</h2>
      </header>
      <ol class="ln-roadmap__timeline">
        {
          learnRoadmap.map((r, i) => (
            <li class={`ln-roadmap-item ln-roadmap-item--${r.tone}`}>
              <span class="ln-roadmap-item__dot" aria-hidden="true" />
              <div class="ln-roadmap-item__body">
                <div class="ln-roadmap-item__meta">
                  <span class="ln-roadmap-item__eta">{r.eta}</span>
                  <span class="ln-roadmap-item__audience">{r.audience}</span>
                </div>
                <h3>{r.title}</h3>
                <p>{r.text}</p>
                {
                  r.interim && (
                    <a href={r.interim.href} class="ln-roadmap-item__interim">
                      Meanwhile: {r.interim.label} →
                    </a>
                  )
                }
              </div>
            </li>
          ))
        }
      </ol>
    </div>
  </section>

  {/* ── FAQ interactive ── */}
  <section class="ln-faq" aria-labelledby="ln-faq-heading">
    <div class="container">
      <header class="ln-faq__header">
        <div>
          <p class="ln-kicker ln-kicker--dark">FAQ</p>
          <h2 id="ln-faq-heading">Common questions about Learn</h2>
        </div>
        <span class="ln-faq__count" aria-hidden="true">{learnFaqs.length} answers</span>
      </header>
      <div class="ln-faq__panel">
        <ul class="ln-faq__list" role="list">
          {
            learnFaqs.map((f, i) => (
              <li>
                <button
                  type="button"
                  class:list={['ln-faq__q', i === 0 && 'is-active']}
                  aria-expanded={i === 0 ? 'true' : 'false'}
                  data-faq-index={i}
                >
                  {f.question}
                </button>
                <div
                  class:list={['ln-faq__a', i === 0 && 'is-open']}
                  hidden={i !== 0}
                >
                  <p>{f.answer}</p>
                </div>
              </li>
            ))
          }
        </ul>
        <aside class="ln-faq__aside" aria-label="Quick links">
          <h3>Pairing cheat sheet</h3>
          <dl>
            <dt>Hospital bill</dt>
            <dd><a href="/learn/how-to-read-medical-bill/">Guide</a> → <a href="/tools/bill-auditor/">Auditor</a></dd>
            <dt>Insurance EOB</dt>
            <dd><a href="/learn/how-to-read-eob/">Guide</a> → <a href="/tools/eob-analyzer/">Analyzer</a></dd>
            <dt>CPT code</dt>
            <dd><a href="/learn/cpt-codes-explained/">Basics</a> → <a href="/tools/fair-price/">Fair Price</a></dd>
            <dt>Medicare</dt>
            <dd><a href="/for/seniors-medicare/">Guide</a> → <a href="/tools/fair-price/?tab=medicare">Lookup</a></dd>
          </dl>
          <p class="ln-faq__aside-foot">
            By <a href={author.path}>{author.name}</a> · Updated {learnMeta.updated}
          </p>
        </aside>
      </div>
      {/* SEO: all FAQ answers in DOM */}
      <div class="visually-hidden" aria-hidden="true">
        {
          learnFaqs.map((f) => (
            <p><strong>{f.question}</strong> {f.answer}</p>
          ))
        }
      </div>
    </div>
  </section>

  {/* ── CTA ── */}
  <section class="ln-cta" aria-label="Get started">
    <div class="container ln-cta__box">
      <div class="ln-cta__copy">
        <h2>Read it, then check it</h2>
        <p>Most patients start with the medical bill guide or Fair Price — both free, both instant.</p>
      </div>
      <div class="ln-cta__actions">
        <a href="/learn/how-to-read-medical-bill/" class="btn btn--primary">Medical bill guide</a>
        <a href="/tools/fair-price/" class="btn btn--secondary">Fair Price Calculator</a>
      </div>
    </div>
  </section>

  <div class="container container--narrow ln-disclaimer">
    <Disclaimer />
  </div>
</BaseLayout>

<script>
  document.querySelectorAll('.ln-faq__q').forEach((btn) => {
    btn.addEventListener('click', () => {
      const idx = btn.getAttribute('data-faq-index');
      document.querySelectorAll('.ln-faq__q').forEach((b) => {
        b.classList.remove('is-active');
        b.setAttribute('aria-expanded', 'false');
      });
      document.querySelectorAll('.ln-faq__a').forEach((a) => {
        a.classList.remove('is-open');
        a.setAttribute('hidden', '');
      });
      btn.classList.add('is-active');
      btn.setAttribute('aria-expanded', 'true');
      const panel = btn.nextElementSibling;
      if (panel?.classList.contains('ln-faq__a')) {
        panel.classList.add('is-open');
        panel.removeAttribute('hidden');
      }
    });
  });
</script>

<style>
  .ln-kicker {
    margin: 0 0 0.625rem;
    font-size: 0.75rem;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--color-accent);
  }

  .ln-kicker--dark { color: var(--color-accent); }
  .ln-kicker--light { color: #5eead4; }

  .ln-section-head {
    margin-bottom: clamp(2rem, 4vw, 2.75rem);
    max-width: 42rem;
  }

  .ln-section-head--center {
    text-align: center;
    margin-inline: auto;
  }

  .ln-section-head h2 {
    margin: 0 0 0.75rem;
    font-family: var(--font-heading);
    font-size: clamp(1.625rem, 3.5vw, 2.25rem);
    letter-spacing: -0.025em;
  }

  .ln-section-lead {
    margin: 0;
    font-size: 1.0625rem;
    line-height: 1.65;
    color: var(--color-muted);
  }

  .ln-section-lead--light {
    color: rgb(203 213 225 / 0.85);
  }

  /* Hero */
  .ln-hero {
    position: relative;
    padding: 2rem 0 2.5rem;
    background: linear-gradient(180deg, #fafaf9 0%, #f0fdfa 55%, #eff6ff 100%);
    border-bottom: 1px solid #e7e5e4;
    overflow: hidden;
  }

  .ln-hero__bg {
    position: absolute;
    inset: 0;
    pointer-events: none;
  }

  .ln-blob {
    position: absolute;
    border-radius: 50%;
    filter: blur(70px);
  }

  .ln-blob--1 {
    width: 18rem;
    height: 18rem;
    top: -4rem;
    right: 10%;
    background: rgb(13 148 136 / 0.2);
  }

  .ln-blob--2 {
    width: 14rem;
    height: 14rem;
    bottom: 0;
    left: -2rem;
    background: rgb(139 92 246 / 0.15);
  }

  .ln-blob--3 {
    width: 10rem;
    height: 10rem;
    top: 40%;
    right: 35%;
    background: rgb(251 191 36 / 0.12);
  }

  .ln-grid {
    position: absolute;
    inset: 0;
    opacity: 0.035;
    background-image: linear-gradient(#64748b 1px, transparent 1px),
      linear-gradient(90deg, #64748b 1px, transparent 1px);
    background-size: 32px 32px;
  }

  .ln-hero__inner {
    position: relative;
    z-index: 1;
  }

  .ln-hero__layout {
    display: grid;
    grid-template-columns: 1fr 1.05fr;
    gap: clamp(1.5rem, 3vw, 2.5rem);
    align-items: center;
  }

  .ln-hero h1 {
    margin: 0 0 1rem;
    font-family: var(--font-heading);
    font-size: clamp(2rem, 4.5vw, 2.875rem);
    font-weight: 700;
    line-height: 1.12;
    letter-spacing: -0.03em;
    color: var(--color-primary);
  }

  .ln-hero__lead {
    margin: 0 0 1.75rem;
    font-size: 1.0625rem;
    line-height: 1.7;
    color: var(--color-muted);
  }

  .ln-hero__actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.875rem;
  }

  .ln-hero__flow {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    padding: 1.25rem;
    border-radius: 1.25rem;
    background: #fff;
    border: 1px solid #e7e5e4;
    box-shadow: 0 8px 32px rgb(15 23 42 / 0.08);
  }

  .ln-hero__flow-label {
    margin: 0 0 0.25rem;
    font-size: 0.6875rem;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-muted);
  }

  .ln-flow-step {
    display: grid;
    grid-template-columns: auto auto 1fr;
    grid-template-rows: auto auto;
    gap: 0.25rem 0.625rem;
    padding: 0.875rem 1rem;
    border-radius: 0.875rem;
    text-decoration: none;
    color: inherit;
    border: 1px solid transparent;
    transition: transform 0.2s, box-shadow 0.2s;
  }

  .ln-flow-step:hover {
    transform: translateX(4px);
    box-shadow: 0 4px 12px rgb(15 23 42 / 0.08);
  }

  .ln-flow-step--violet {
    background: linear-gradient(135deg, #f5f3ff, #ede9fe);
    border-color: #c4b5fd;
    color: #5b21b6;
  }

  .ln-flow-step--teal {
    background: linear-gradient(135deg, #f0fdfa, #ccfbf1);
    border-color: #5eead4;
    color: #0f766e;
  }

  .ln-flow-step--blue {
    background: linear-gradient(135deg, #eff6ff, #dbeafe);
    border-color: #93c5fd;
    color: #1e40af;
  }

  .ln-flow-step__num {
    grid-row: 1 / 3;
    display: grid;
    place-items: center;
    width: 1.75rem;
    height: 1.75rem;
    border-radius: 50%;
    font-size: 0.75rem;
    font-weight: 800;
    background: #fff;
    border: 1px solid rgb(0 0 0 / 0.08);
  }

  .ln-flow-step__emoji {
    font-size: 1.125rem;
    line-height: 1;
  }

  .ln-flow-step__label {
    font-size: 0.5625rem;
    font-weight: 800;
    letter-spacing: 0.1em;
    opacity: 0.75;
  }

  .ln-flow-step__title {
    grid-column: 2 / 4;
    font-size: 0.875rem;
    font-weight: 700;
  }

  .ln-flow-step__text {
    grid-column: 2 / 4;
    font-size: 0.75rem;
    line-height: 1.45;
    opacity: 0.85;
  }

  .ln-flow-arrow {
    text-align: center;
    font-size: 1rem;
    color: var(--color-muted);
    opacity: 0.5;
    line-height: 1;
  }

  /* Trust strip */
  .ln-trust-strip {
    padding: 1rem 0;
    background: #fff;
    border-bottom: 1px solid #e7e5e4;
  }

  .ln-trust-strip__grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 0.625rem;
  }

  .ln-trust-chip {
    padding: 0.75rem 1rem;
    border-radius: 0.875rem;
    border: 1px solid transparent;
  }

  .ln-trust-chip strong {
    display: block;
    font-size: 0.8125rem;
    font-weight: 700;
    margin-bottom: 0.15rem;
  }

  .ln-trust-chip span {
    font-size: 0.6875rem;
    line-height: 1.4;
    opacity: 0.85;
  }

  .ln-trust-chip--violet { background: #f5f3ff; border-color: #ddd6fe; color: #5b21b6; }
  .ln-trust-chip--teal { background: #f0fdfa; border-color: #99f6e4; color: #0f766e; }
  .ln-trust-chip--blue { background: #eff6ff; border-color: #bfdbfe; color: #1e40af; }
  .ln-trust-chip--amber { background: #fffbeb; border-color: #fde68a; color: #92400e; }

  /* Pipeline — dark band */
  .ln-pipeline {
    padding: clamp(2.5rem, 5vw, 3.5rem) 0;
    background: linear-gradient(155deg, #0f172a 0%, #1e293b 100%);
    color: #f8fafc;
  }

  .ln-pipeline__head {
    text-align: center;
    max-width: 36rem;
    margin: 0 auto clamp(2rem, 4vw, 2.5rem);
  }

  .ln-pipeline__head h2 {
    margin: 0 0 0.625rem;
    font-family: var(--font-heading);
    font-size: clamp(1.375rem, 3vw, 1.875rem);
    color: #fff;
  }

  .ln-pipeline__head p {
    margin: 0;
    color: rgb(203 213 225 / 0.85);
    line-height: 1.6;
  }

  .ln-pipeline__track {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1rem;
    position: relative;
  }

  .ln-pipeline__track::before {
    content: '';
    position: absolute;
    top: 3.5rem;
    left: 16%;
    right: 16%;
    height: 2px;
    background: linear-gradient(90deg, #8b5cf6, #0d9488, #3b82f6);
    opacity: 0.4;
    pointer-events: none;
  }

  .ln-pipeline__step {
    padding: 1.5rem;
    border-radius: 1.25rem;
    background: rgb(255 255 255 / 0.06);
    border: 1px solid rgb(255 255 255 / 0.12);
    text-align: center;
    position: relative;
  }

  .ln-pipeline__step--violet { border-top: 3px solid #a78bfa; }
  .ln-pipeline__step--teal { border-top: 3px solid #2dd4bf; }
  .ln-pipeline__step--blue { border-top: 3px solid #60a5fa; }

  .ln-pipeline__badge {
    display: inline-block;
    margin-bottom: 0.5rem;
    font-size: 0.625rem;
    font-weight: 800;
    letter-spacing: 0.12em;
    padding: 0.25rem 0.625rem;
    border-radius: 999px;
