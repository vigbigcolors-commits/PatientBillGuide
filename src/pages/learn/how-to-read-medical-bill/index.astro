import { site } from '../../../data/site';
import { author, getAuthorUrl } from '../../../data/author';
import { articleSchema, faqPageSchema, breadcrumbSchema } from '../../../lib/seo/schema';

const updated = '2026-06-29';
const pageUrl = '/learn/how-to-read-medical-bill/';
const canonical = new URL(pageUrl, site.url).href;
const title = 'How to Read a Medical Bill (Itemized Hospital Bill)';
const description =
  'Plain-English guide to reading itemized hospital and clinic bills — CPT codes, facility vs. professional fees, chargemaster prices, and self-pay negotiation basics.';

const faqs = [
  {
    question: 'What is the difference between a hospital bill and an EOB?',
    answer:
      'A hospital or clinic bill is a request for payment from the provider. An EOB is your insurer\'s explanation of how a claim was processed. You need both to confirm what you actually owe.',
  },
  {
    question: 'Why does my bill list so many separate charges?',
    answer:
      'Hospitals bill facility fees, supplies, and room charges. Physicians who treated you (emergency doctors, radiologists, anesthesiologists) often bill separately under their own tax IDs. Each line may have its own CPT code.',
  },
  {
    question: 'What is a chargemaster?',
    answer:
      'A chargemaster is the hospital\'s internal list of standard charges for every service and supply. Listed prices are often much higher than what insurers pay. Self-pay patients may be quoted chargemaster rates unless they negotiate or qualify for financial assistance.',
  },
  {
    question: 'What are facility fees vs. professional fees?',
    answer:
      'Facility fees cover the hospital\'s overhead — equipment, nursing, space — for a service. Professional fees pay the clinician who performed or interpreted the service. A single MRI may produce both types of charges on separate bills.',
  },
  {
    question: 'Can I negotiate a medical bill if I am uninsured?',
    answer:
      'Yes. Many hospitals offer financial assistance, prompt-pay discounts, or cash rates lower than chargemaster prices. Ask for an itemized bill, compare charges to Medicare benchmarks, and request a written self-pay quote before paying.',
  },
  {
    question: 'Where do CPT codes appear on a bill?',
    answer:
      'Look for columns labeled CPT, HCPCS, procedure code, or revenue code. Each billable service usually has a five-digit CPT code (or a HCPCS code for supplies and certain drugs). See our CPT guide for help decoding them.',
  },
  {
    question: 'What tool can help me review line items?',
    answer:
      'PatientBillGuide\'s Bill Auditor lets you paste itemized charges in your browser. It flags common patterns and compares amounts to Medicare data. Pair it with the Fair Price Calculator for individual codes.',
  },
];

const schemaGraph = [
  articleSchema({
    headline: title,
    description,
    url: canonical,
    dateModified: updated,
    authorName: author.name,
    authorUrl: getAuthorUrl(site.url),
    authorJobTitle: author.jobTitle,
  }),
  faqPageSchema(faqs),
  breadcrumbSchema(
    [
      { name: 'Home', url: '/' },
      { name: 'Learn', url: '/learn/' },
      { name: 'How to Read a Medical Bill' },
    ],
    site.url,
  ),
];
---

<LegalLayout
