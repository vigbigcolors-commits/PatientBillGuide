---
import ToolLayout from '../../../layouts/ToolLayout.astro';
import ToolExamples from '../../../components/tools/ToolExamples.astro';
import MethodologyFooter from '../../../components/MethodologyFooter.astro';
import Disclaimer from '../../../components/Disclaimer.astro';
import { site } from '../../../data/site';
import { fairPriceExamples, medicareLookupExamples } from '../../../data/tool-examples';
import {
  PART_B_DEDUCTIBLE_2026,
  PART_B_GLOSSARY,
  PART_B_PIPELINE_LANES,
} from '../../../lib/pricing/medicare-part-b';
import { faqPageSchema, webApplicationSchema, breadcrumbSchema } from '../../../lib/seo/schema';

const faqs = [
  {
    question: 'What is a fair price range?',
    answer:
      'We use 1.5× to 2.5× the Medicare allowed amount as an educational benchmark for typical commercial or self-pay charges — documented in our methodology, not a legal maximum.',
  },
  {
    question: 'Does Medicare rate include hospital facility fees?',
    answer:
      'No. This tool uses non-facility physician fee schedule rates. Hospital outpatient and ER facility fees are separate line items.',
  },
  {
    question: 'Why is my ZIP showing national median?',
    answer:
      'We map 42,000+ US ZIP codes to CMS Medicare localities. Unmapped or invalid ZIPs use the national median rate.',
  },
  {
    question: 'Is my search private?',
    answer: 'Yes. All calculations run in your browser. We do not receive your codes, ZIP, or prices.',
  },
  {
    question: 'What CPT codes are supported?',
    answer:
      'We support 7,700+ Medicare fee schedule codes (office visits, ER, imaging, labs, surgery, and more) from the CMS April 2026 RVU file, localized to 42,000+ US ZIP codes.',
  },
  {
    question: 'Can a charge above fair range be correct?',
    answer:
      'Yes. Out-of-network care, facility fees, and bundled hospital pricing can exceed 2.5× Medicare without being a billing error.',
  },
  {
    question: 'What is the Medicare Part B tab?',
    answer:
      'Same CMS allowed amount as Fair Price, plus an estimated patient share that applies the Part B deductible first, then typical 80/20 coinsurance. It is an educational estimate — not your MSN or legal advice.',
  },
  {
    question: 'Does Medigap change my Part B estimate?',
    answer:
      'Yes. Plans like G and N often pay coinsurance after Medicare pays. This tab shows Traditional Medicare math only — check your supplement policy for what it covers.',
  },
  {
    question: 'What about Medicare Advantage?',
    answer:
      'Medicare Advantage plans use different networks and copays. CMS allowed amounts here are Traditional Medicare benchmarks — compare to your plan EOB, not this estimate alone.',
  },
  {
    question: 'Are preventive services $0?',
    answer:
      'Many in-network preventive services (annual wellness visit, screening mammogram) show $0 patient responsibility under Traditional Medicare. This tool still shows the CMS allowed amount for context.',
  },
  {
    question: 'Is this medical or legal advice?',
    answer: 'No. PatientBillGuide is an independent educational guide. See our disclaimer.',
  },
];

const schemaGraph = [
  webApplicationSchema({
    name: 'Fair Price Calculator',
    description: 'Compare medical charges to Medicare benchmarks and fair price ranges by CPT and ZIP.',
    url: `${site.url}/tools/fair-price/`,
  }),
  faqPageSchema(faqs),
  breadcrumbSchema(
    [{ name: 'Home', url: '/' }, { name: 'Tools', url: '/tools/' }, { name: 'Fair Price Calculator' }],
    site.url,
  ),
];
---

<ToolLayout
  title="Fair Price Calculator"
  description="Enter a CPT procedure code and ZIP to compare your price against Medicare benchmarks. Free, private, browser-based."
  crumbs={[
    { label: 'Home', href: '/' },
    { label: 'Tools', href: '/tools/' },
    { label: 'Fair Price Calculator' },
  ]}
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(schemaGraph)} />
  </Fragment>
  <Fragment slot="intro">
    <p>
      Enter a CPT procedure code and optionally your ZIP and the price you were charged. Compare against
      Medicare benchmarks and a typical fair range — or switch to the <strong>Medicare Part B</strong> tab for
      coinsurance estimates.
    </p>
    <div class="facility-inline-notice" data-tab-content="fair" role="note">
      <strong>Physician fee only.</strong> Medicare allowed amounts here do not include hospital outpatient,
      ER, or imaging <em>facility fees</em> — often billed on separate lines.
      <a href="/learn/how-to-read-medical-bill/#facility-professional">Facility vs professional →</a>
    </div>
    <div class="medicare-inline-notice" data-tab-content="medicare" hidden role="note">
      <strong>Traditional Medicare Part B.</strong> Estimate applies the {PART_B_DEDUCTIBLE_2026} annual
      deductible, then 80/20 coinsurance. Medigap, Medicare Advantage, and Medicaid work differently —
      compare to your <a href="/for/seniors-medicare/">MSN or plan EOB</a>.
    </div>
  </Fragment>

  <div class="tool-tabs" role="tablist" aria-label="Calculator mode">
    <button
      type="button"
      class="tool-tab tool-tab--active"
      id="tab-fair"
      role="tab"
      data-price-tab="fair"
      aria-selected="true"
      aria-controls="calculator-panel"
      tabindex="0"
    >
      Fair price check
    </button>
    <button
      type="button"
      class="tool-tab"
      id="tab-medicare"
      role="tab"
      data-price-tab="medicare"
      aria-selected="false"
      aria-controls="calculator-panel"
      tabindex="-1"
    >
      Medicare Part B estimate
    </button>
  </div>

  <section class="part-b-lanes card" data-tab-content="medicare" hidden aria-label="How Part B cost-sharing works">
    <h2 class="part-b-lanes__title">Part B cost-sharing pipeline</h2>
    <ul class="part-b-lanes__grid">
      {PART_B_PIPELINE_LANES.map((lane) => (
        <li class={`part-b-lane part-b-lane--${lane.level}`}>
          <span class="part-b-lane__title">{lane.title}</span>
          <span class="part-b-lane__detail">{lane.detail}</span>
        </li>
      ))}
    </ul>
  </section>

  <section class="part-b-glossary card" data-tab-content="medicare" hidden aria-label="Medicare Part B glossary">
    <h2 class="part-b-glossary__title">Term guide</h2>
    <dl class="part-b-glossary__grid">
      {PART_B_GLOSSARY.map((item) => (
        <div>
          <dt>{item.term}</dt>
          <dd>{item.meaning}</dd>
        </div>
      ))}
    </dl>
  </section>

  <div id="calculator-panel" role="tabpanel" aria-labelledby="tab-fair">
  <form class="calculator card tool-form tool-form--teal" id="fair-price-form">
    <div class="field">
      <label class="input-label" for="cpt">
        CPT procedure code <span class="required" aria-hidden="true">*</span>
      </label>
      <div class="cpt-combobox">
        <input
          class="input-field"
          id="cpt"
          name="cpt"
          type="text"
          inputmode="numeric"
          placeholder="e.g. 99213"
          autocomplete="off"
          role="combobox"
          aria-autocomplete="list"
          aria-expanded="false"
          aria-controls="cpt-suggestions"
          required
        />
        <ul id="cpt-suggestions" class="cpt-suggestions" role="listbox" hidden></ul>
      </div>
      <p class="input-hint">Found on your bill or EOB — start typing for suggestions</p>
    </div>

    <div class="field">
      <label class="input-label" for="zip">ZIP code</label>
      <div class="input-with-icon">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" aria-hidden="true">
          <path d="M12 21s7-5.5 7-11a7 7 0 10-14 0c0 5.5 7 11 7 11z" stroke="currentColor" stroke-width="1.5" />
          <circle cx="12" cy="10" r="2.5" stroke="currentColor" stroke-width="1.5" />
        </svg>
        <input
          class="input-field"
          id="zip"
          name="zip"
          type="text"
          inputmode="numeric"
          placeholder="e.g. 90210"
          maxlength="5"
          autocomplete="postal-code"
        />
      </div>
      <p class="input-hint">Helps localize rates to your region</p>
    </div>

    <div class="field" data-field="price">
      <label class="input-label" for="price">Price you were charged</label>
      <input
        class="input-field"
        id="price"
        name="price"
        type="text"
        inputmode="decimal"
        placeholder="$0.00"
        autocomplete="off"
      />
      <p class="input-hint">Optional — compare your bill to the fair range. Facility fees may be on other lines.</p>
    </div>

    <div class="field" data-field="deductible" hidden>
      <label class="input-label" for="deductible-met">Part B deductible already met this year</label>
      <input
        class="input-field"
        id="deductible-met"
        name="deductible-met"
        type="text"
        inputmode="decimal"
        placeholder="$0"
        autocomplete="off"
      />
      <p class="input-hint">Optional — enter how much of the {PART_B_DEDUCTIBLE_2026} annual deductible you have already paid in 2026.</p>
    </div>

    <button type="submit" class="btn btn--primary">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" aria-hidden="true">
        <circle cx="11" cy="11" r="7" stroke="currentColor" stroke-width="2" />
        <path d="M16 16l4 4" stroke="currentColor" stroke-width="2" stroke-linecap="round" />
      </svg>
      <span id="fair-price-submit-label">Check price</span>
    </button>
    <p class="calculator__note" role="status">
      Uses CMS Medicare Physician Fee Schedule data. All calculations run in your browser.
    </p>
  </form>
  </div>

  <div id="fair-price-loading" class="fair-price-loading" hidden role="status" aria-live="polite">
    <span class="fair-price-loading__spinner" aria-hidden="true"></span>
    <span>Fetching CMS data… first lookup may take a few seconds.</span>
  </div>

  <div id="fair-price-error" class="fair-price-error" hidden></div>
  <div id="fair-price-results" hidden></div>

  <div data-tab-content="fair">
    <ToolExamples variant="fair-price" examples={fairPriceExamples} />
  </div>

  <div data-tab-content="medicare" hidden>
    <ToolExamples
      variant="medicare-lookup"
      title="Medicare Part B examples"
      hint="Click to load — we estimate automatically with deductible context."
      examples={medicareLookupExamples}
    />
  </div>

  <section class="tool-faq card">
    <h2>FAQ</h2>
    <dl class="faq">
      {faqs.map((f) => (
        <>
          <dt>{f.question}</dt>
          <dd>{f.answer}</dd>
        </>
      ))}
    </dl>
  </section>

  <Disclaimer />

  <div slot="sidebar">
    <div class="sidebar-card card" data-tab-content="fair">
      <h2>What this means</h2>
      <ul class="means-list">
        <li>
          <strong>Medicare allowed amount</strong> — CMS-approved physician fee for this code,
          localized to your Medicare area when you enter a ZIP; otherwise the national rate.
        </li>
        <li>
          <strong>Fair range (1.5×–2.5×)</strong> — typical self-pay or commercial charges above
          Medicare, per our methodology.
        </li>
        <li>
          <strong>Your price comparison</strong> — where your charge falls relative to that range.
        </li>
        <li>
          <strong>Confidence level</strong> — how complete the public data is for this code and
          area.
        </li>
      </ul>
    </div>

    <div class="sidebar-card card" data-tab-content="medicare" hidden>
      <h2>Part B estimate</h2>
      <ul class="means-list means-list--medicare">
        <li>
          <strong>Allowed amount</strong> — CMS physician fee for this CPT in your Medicare locality.
        </li>
        <li>
          <strong>Deductible ({PART_B_DEDUCTIBLE_2026}/yr)</strong> — you pay 100% of approved amounts until met.
        </li>
        <li>
          <strong>Coinsurance (20%)</strong> — your share after deductible on each approved service.
        </li>
        <li>
          <strong>Medigap / Advantage</strong> — supplements and MA plans change what you actually owe.
        </li>
      </ul>
    </div>

    <div class="sidebar-card card" data-tab-content="medicare" hidden>
      <h2>After you estimate</h2>
      <ul>
        <li><a href="/for/seniors-medicare/">Medicare patient guide</a></li>
        <li><a href="/tools/eob-analyzer/">EOB Analyzer</a></li>
        <li><a href="/tools/bill-auditor/">Bill Auditor</a></li>
        <li><a href="/learn/how-to-read-eob/">How to read an EOB</a></li>
      </ul>
    </div>

    <div class="privacy-card" data-tab-content="both">
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" aria-hidden="true">
        <path d="M12 2l7 4v5c0 5-3.5 9.5-7 11-3.5-1.5-7-6-7-11V6l7-4z" stroke="currentColor" stroke-width="1.5" />
      </svg>
      <div>
        <strong>Your privacy is protected</strong>
        <p>
          All calculations happen in your browser. We never see your CPT codes, ZIP, or bill amount.
          Nothing is stored or transmitted.
        </p>
      </div>
    </div>

    <MethodologyFooter />
  </div>
</ToolLayout>

<script>
  import '../../../scripts/fair-price.ts';
</script>

<style>
  .calculator .field {
    margin-bottom: var(--space-lg);
  }

  #calculator-panel .calculator {
    overflow: visible;
  }

  .calculator button[type='submit'] {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    width: 100%;
    margin-top: var(--space-sm);
  }

  .calculator button[type='submit']:disabled {
    opacity: 0.72;
    cursor: wait;
  }

  .calculator button[type='submit'] svg {
    flex-shrink: 0;
  }

  .facility-inline-notice {
    margin-top: var(--space-md);
    padding: var(--space-md);
    background: #f0f9ff;
    border: 1px solid #bae6fd;
    border-radius: var(--radius-md);
    font-size: 0.875rem;
    line-height: 1.55;
    color: #0c4a6e;
  }

  .facility-inline-notice a {
    font-weight: 600;
  }

  .tool-tabs {
    display: flex;
    gap: 0.5rem;
    margin-bottom: var(--space-lg);
    flex-wrap: wrap;
  }

  @media (max-width: 500px) {
    .tool-tabs {
      display: grid;
      grid-template-columns: 1fr 1fr;
    }

    .tool-tab {
      text-align: center;
      padding-inline: 0.5rem;
      font-size: 0.8125rem;
    }
  }

  .tool-tab {
    padding: 0.625rem 1rem;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-btn);
    background: #fff;
    font: inherit;
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--color-muted);
    cursor: pointer;
  }

  .tool-tab--active[data-price-tab='fair'] {
    background: #0d9488;
    border-color: #0d9488;
    color: #fff;
  }

  .tool-tab--active[data-price-tab='medicare'] {
    background: #059669;
    border-color: #059669;
    color: #fff;
  }

  .tool-tab:focus-visible {
    outline: 2px solid var(--color-accent);
    outline-offset: 2px;
  }

  .cpt-combobox {
    position: relative;
  }

  .cpt-suggestions {
    position: absolute;
    z-index: 20;
    top: calc(100% + 0.25rem);
    left: 0;
    right: 0;
    margin: 0;
    padding: 0.25rem 0;
    list-style: none;
    background: #fff;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    box-shadow: 0 8px 24px rgb(15 23 42 / 0.12);
    max-height: 14rem;
    overflow-y: auto;
  }

  .cpt-suggestion {
    display: grid;
    grid-template-columns: 4.5rem 1fr;
    gap: 0.5rem;
    padding: 0.5rem 0.75rem;
    font-size: 0.875rem;
    cursor: pointer;
  }

  .cpt-suggestion:hover,
  .cpt-suggestion[aria-selected='true'] {
    background: var(--color-accent-bg);
  }

  .cpt-suggestion__code {
    font-family: var(--font-mono);
    font-weight: 700;
    color: var(--color-accent);
  }

  .cpt-suggestion__desc {
    color: var(--color-muted);
    line-height: 1.35;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .fair-price-loading {
    display: flex;
    align-items: center;
    gap: var(--space-md);
    margin-top: var(--space-lg);
    padding: var(--space-md) var(--space-lg);
    background: #f0f9ff;
    border: 1px solid #bae6fd;
    border-radius: var(--radius-md);
    font-size: 0.875rem;
    color: #0c4a6e;
  }

  .fair-price-loading__spinner {
    width: 1.125rem;
    height: 1.125rem;
    border: 2px solid #bae6fd;
    border-top-color: #0284c7;
    border-radius: 50%;
    animation: fair-price-spin 0.7s linear infinite;
    flex-shrink: 0;
  }

  @keyframes fair-price-spin {
    to {
      transform: rotate(360deg);
    }
  }

  .part-b-estimate {
    margin: var(--space-md) 0;
    padding: var(--space-md);
    background: #ecfdf5;
    border: 1px solid #a7f3d0;
    border-radius: var(--radius-md);
    color: #065f46;
  }

  .part-b-estimate__headline {
    margin: 0 0 0.375rem;
    font-weight: 700;
    font-size: 0.9375rem;
  }

  .part-b-estimate__detail {
    margin: 0;
    font-size: 0.875rem;
    line-height: 1.55;
  }

  .input-with-icon {
    position: relative;
  }

  .input-with-icon svg {
    position: absolute;
    left: 0.875rem;
    top: 50%;
    transform: translateY(-50%);
    color: var(--color-muted);
    pointer-events: none;
  }

  .input-with-icon .input-field {
    padding-left: 2.5rem;
  }

  .calculator__note {
    margin: var(--space-md) 0 0;
    font-size: 0.8125rem;
  }

  .sidebar-card h2 {
    font-size: 1rem;
    margin-bottom: var(--space-md);
  }

  .means-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    gap: var(--space-md);
    font-size: 0.875rem;
    color: var(--color-muted);
  }

  .means-list li {
    padding-left: 1rem;
    border-left: 3px solid var(--color-accent);
  }

  .means-list strong {
    display: block;
    color: var(--color-primary);
    font-size: 0.9rem;
    margin-bottom: 0.125rem;
  }

  .privacy-card {
    display: flex;
    gap: var(--space-md);
    margin-top: var(--space-lg);
    padding: var(--space-lg);
    background: var(--color-accent-bg);
    border: 1px solid #99f6e4;
    border-radius: var(--radius-xl);
    font-size: 0.875rem;
    color: #115e59;
  }

  .privacy-card svg {
    flex-shrink: 0;
    margin-top: 0.125rem;
  }

  .privacy-card strong {
    display: block;
    margin-bottom: 0.25rem;
    color: #0f766e;
  }

  .privacy-card p {
    margin: 0;
    line-height: 1.5;
  }

  .fair-price-error {
    margin-top: var(--space-lg);
    padding: var(--space-md);
    background: #fef2f2;
    border: 1px solid #fecaca;
    border-radius: var(--radius-md);
    color: #991b1b;
    font-size: 0.875rem;
  }

  #fair-price-results {
    margin-top: var(--space-lg);
  }

  #fair-price-results :global(.price-results__highlight) {
    grid-column: 1 / -1;
    padding: var(--space-md);
    background: #ecfdf5;
    border: 1px solid #a7f3d0;
    border-radius: var(--radius-md);
  }

  #fair-price-results :global(.price-results__highlight dt) {
    color: #065f46;
  }

  #fair-price-results :global(.price-results__highlight dd) {
    font-size: 1.375rem;
    color: #047857;
  }

  #fair-price-results :global(.price-results) {
    animation: fair-price-fade-in 0.25s ease-out;
  }

  @keyframes fair-price-fade-in {
    from {
      opacity: 0;
      transform: translateY(0.35rem);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .tool-faq {
    margin-top: var(--space-xl);
  }

  .tool-faq h2 {
    font-size: 1.125rem;
    margin: 0 0 var(--space-md);
  }

  .medicare-inline-notice {
    margin-top: var(--space-md);
    padding: var(--space-md);
    background: #ecfdf5;
    border: 1px solid #a7f3d0;
    border-radius: var(--radius-md);
    font-size: 0.875rem;
    line-height: 1.55;
    color: #065f46;
  }

  .medicare-inline-notice a {
    font-weight: 600;
  }

  .part-b-lanes {
    margin-bottom: var(--space-lg);
    background: linear-gradient(135deg, #ecfdf5 0%, #d1fae5 50%, #a7f3d0 100%);
    border-color: #6ee7b7;
  }

  .part-b-lanes__title {
    font-size: 1rem;
    margin: 0 0 var(--space-md);
    color: #047857;
  }

  .part-b-lanes__grid {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(11rem, 1fr));
    gap: var(--space-sm);
  }

  .part-b-lane {
    padding: 0.75rem;
    border-radius: var(--radius-md);
    border: 1px solid transparent;
    font-size: 0.8125rem;
  }

  .part-b-lane--strong {
    background: #fff;
    border-color: #6ee7b7;
  }

  .part-b-lane--weak {
    background: #f0fdf4;
    border-color: #bbf7d0;
  }

  .part-b-lane__title {
    display: block;
    font-weight: 700;
    color: var(--color-primary);
    margin-bottom: 0.25rem;
  }

  .part-b-lane__detail {
    color: var(--color-muted);
    line-height: 1.4;
  }

  .part-b-glossary {
    margin-bottom: var(--space-xl);
    background: #f8fafc;
    border-color: var(--color-border);
  }

  .part-b-glossary__title {
    font-size: 1rem;
    margin: 0 0 var(--space-md);
  }

  .part-b-glossary__grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(12rem, 1fr));
    gap: var(--space-md);
    margin: 0;
  }

  .part-b-glossary__grid dt {
    font-weight: 700;
    font-size: 0.875rem;
    color: #047857;
    margin-bottom: 0.25rem;
  }

  .part-b-glossary__grid dd {
    margin: 0;
    font-size: 0.8125rem;
    color: var(--color-muted);
    line-height: 1.45;
  }

  .means-list--medicare li {
    border-left-color: #10b981;
  }
</style>

<style is:global>
  #fair-price-results .part-b-owe-highlight {
    margin-bottom: var(--space-lg);
    padding: var(--space-lg);
    background: #ecfdf5;
