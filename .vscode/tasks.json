{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "PatientBillGuide: Dev Server",
      "type": "npm",
      "script": "dev",
      "isBackground": true,
      "problemMatcher": {
        "owner": "astro",
        "pattern": { "regexp": "." },
        "background": {
          "activeOnStart": true,
          "beginsPattern": ".",
          "endsPattern": "(Local|localhost:4321)"
        }
      },
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "focus": false
      },
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "runOptions": {
        "runOn": "folderOpen"
      }
    },
    {
      "label": "PatientBillGuide: Build",
      "type": "npm",
      "script": "build",
      "problemMatcher": [],
      "group": "build"
    },
    {
      "label": "PatientBillGuide: Preview (production)",
      "type": "npm",
      "script": "preview",
      "dependsOn": "PatientBillGuide: Build",
      "problemMatcher": [],
      "isBackground": true,
      "presentation": {
        "reveal": "always",
        "panel": "dedicated"
      }
    },
    {
      "label": "PatientBillGuide: Test",
      "type": "npm",
      "script": "test",
      "problemMatcher": []
    }
  ]
}
